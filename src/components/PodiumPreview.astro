---
import { defaultScoringConfig, scoreOmnium } from "../lib/scoring";
import { loadAthleteResults } from "../lib/athlete-loader";

const { riders, hasLiveData } = loadAthleteResults();
const leaderboards = scoreOmnium(riders, defaultScoringConfig);

const scoreFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});

const podiumData = leaderboards.map((board) => ({
  categoryLabel: board.categoryLabel,
  categoryId: board.categoryId,
  top3: board.entries.slice(0, 3),
}));
---

{hasLiveData ? (
  <div class="podium-root">
    <div class="podium-grid">
      {podiumData.map((category) => (
        <div class="podium-card">
          <p class="podium-category">{category.categoryLabel}</p>
          {category.top3.length > 0 ? (
            <ol class="podium-list">
              {category.top3.map((entry) => (
                <li class:list={["podium-entry", entry.rank === 1 ? "podium-entry--first" : ""]}>
                  <span class="podium-rank">{entry.rank}</span>
                  <span class="podium-name">{entry.rider.name}</span>
                  <span class="podium-score">{scoreFormatter.format(entry.totalScore)}</span>
                </li>
              ))}
            </ol>
          ) : (
            <p class="podium-empty">No riders yet.</p>
          )}
        </div>
      ))}
    </div>
    <div class="podium-action">
      <a href="/leaderboard" class="primary-button">View Full Leaderboard</a>
    </div>
  </div>
) : (
  <div class="podium-placeholder">
    <p class="podium-placeholder__label">Leaderboard opens after submissions begin</p>
    <a href="/leaderboard" class="primary-button" style="margin-top: 1.5rem;">Go to Leaderboard</a>
  </div>
)}

<style>
  .podium-root {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .podium-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .podium-grid {
      grid-template-columns: 1fr;
    }
  }

  .podium-card {
    background: var(--color-surface-raised, #ffffff);
    border: 1px solid rgba(19, 28, 26, 0.08);
    border-radius: 4px;
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .podium-category {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }

  .podium-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .podium-entry {
    display: grid;
    grid-template-columns: 1.5rem 1fr auto;
    align-items: baseline;
    gap: 0.5rem;
  }

  .podium-rank {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    line-height: 1;
  }

  .podium-entry--first .podium-rank {
    font-size: 1.35rem;
    color: var(--color-night-900);
  }

  .podium-name {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .podium-entry--first .podium-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-night-900);
  }

  .podium-score {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }

  .podium-entry--first .podium-score {
    font-size: 0.88rem;
    color: var(--color-night-900);
    font-weight: 700;
  }

  .podium-empty {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .podium-action {
    display: flex;
    justify-content: flex-start;
  }

  .podium-placeholder {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem 0;
  }

  .podium-placeholder__label {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink-muted);
  }
</style>
