---
import { defaultScoringConfig, formatDuration, scoreOmnium } from "../lib/scoring";
import { loadAthleteResults } from "../lib/athlete-loader";

const { riders, hasLiveData } = loadAthleteResults();
const leaderboards = scoreOmnium(riders, defaultScoringConfig);

const scoreFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
---

<div class="leaderboard-shell" data-leaderboard>
  <div class="leaderboard-head">
    <div class="leaderboard-intro">
      <p class="eyebrow">{hasLiveData ? "Live Results" : "Awaiting Submissions"}</p>
      <h3 class="leaderboard-title">Overall winners are calculated inside each category.</h3>
    </div>
    {hasLiveData && (
      <input
        type="search"
        class="search-input"
        placeholder="Search riders..."
        aria-label="Search leaderboard by rider name"
        data-search
      />
    )}
    {hasLiveData && (
      <div class="tab-list" role="tablist" aria-label="Leaderboard categories">
        {leaderboards.map((board, index) => (
          <button
            class:list={{ "tab-button": true, "is-active": index === 0 }}
            type="button"
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`panel-${board.categoryId}`}
            data-target={board.categoryId}
          >
            {board.categoryLabel}
          </button>
        ))}
      </div>
    )}
  </div>

  {hasLiveData ? (
    leaderboards.map((board, index) => {
      return (
        <section
          id={`panel-${board.categoryId}`}
          class="leaderboard-panel"
          role="tabpanel"
          data-panel={board.categoryId}
          hidden={index !== 0}
        >
          {board.entries.length > 0 ? (
            <div class="winner-banner">
              <div>
                <p class="winner-label">Projected category winner</p>
                <h4 class="winner-name">{board.entries[0].rider.name}</h4>
                <p class="winner-meta">{scoreFormatter.format(board.entries[0].totalScore)} total points</p>
              </div>
              <div class="benchmark-grid">
                <div>
                  <span>Fastest moving time</span>
                  <strong>{formatDuration(board.benchmarks.fastestMovingTimeSeconds)}</strong>
                </div>
                <div>
                  <span>Fastest sectors</span>
                  <strong>{formatDuration(board.benchmarks.fastestSectorTotalSeconds)}</strong>
                </div>
                <div>
                  <span>Most KOM points</span>
                  <strong>{board.benchmarks.highestKomPoints}</strong>
                </div>
              </div>
            </div>
          ) : (
            <div class="category-empty">
              <p>No {board.categoryLabel.toLowerCase()} riders yet.</p>
            </div>
          )}

          {board.entries.length > 0 && (
            <div class="leaderboard-table-wrap">
              <table class="leaderboard-table">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Rider</th>
                    <th scope="col">Day 1</th>
                    <th scope="col">Day 2 Sectors</th>
                    <th scope="col">KOM</th>
                    <th scope="col">Total</th>
                  </tr>
                </thead>
                <tbody>
                  {board.entries.map((entry) => (
                    <tr>
                      <td class="rank-cell">
                        <span class="rank-pill">{entry.rank}</span>
                      </td>
                      <td>
                        <div class="rider-name">{entry.rider.name}</div>
                      </td>
                      <td>
                        <strong>{scoreFormatter.format(entry.movingTimeScore)}</strong>
                        <div class="score-note">{formatDuration(entry.rider.movingTimeSeconds)}</div>
                      </td>
                      <td>
                        <strong>{scoreFormatter.format(entry.sectorScore)}</strong>
                        <div class="score-note">{formatDuration(entry.sectorTotalTimeSeconds)}</div>
                      </td>
                      <td>
                        <strong>{scoreFormatter.format(entry.komScore)}</strong>
                        <div class="score-note">{entry.rider.komPoints} pts</div>
                      </td>
                      <td class="total-cell">{scoreFormatter.format(entry.totalScore)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      );
    })
  ) : (
    <div class="leaderboard-empty">
      <p class="leaderboard-empty-text">Results will appear here after riders submit.</p>
    </div>
  )}
</div>

<script>
  const leaderboards = document.querySelectorAll("[data-leaderboard]");

  for (const leaderboard of leaderboards) {
    /** @type {NodeListOf<HTMLButtonElement>} */
    const buttons = leaderboard.querySelectorAll("[data-target]");
    /** @type {NodeListOf<HTMLElement>} */
    const panels = leaderboard.querySelectorAll("[data-panel]");

    for (const button of buttons) {
      button.addEventListener("click", () => {
        const target = button.getAttribute("data-target");

        for (const candidate of buttons) {
          const isActive = candidate === button;
          candidate.classList.toggle("is-active", isActive);
          candidate.setAttribute("aria-selected", String(isActive));
        }

        for (const panel of panels) {
          if (panel instanceof HTMLElement) {
            panel.hidden = panel.getAttribute("data-panel") !== target;
          }
        }
      });
    }

    const searchInput = leaderboard.querySelector<HTMLInputElement>('[data-search]');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        const allRows = leaderboard.querySelectorAll<HTMLTableRowElement>('tbody tr');
        for (const row of allRows) {
          const name = row.querySelector('.rider-name')?.textContent?.toLowerCase() ?? '';
          const matches = query === '' || name.includes(query);
          row.classList.toggle('search-hidden', !matches);
        }
      });
    }
  }
</script>
