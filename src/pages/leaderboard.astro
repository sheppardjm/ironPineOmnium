---
import BaseLayout from "../layouts/BaseLayout.astro";
import Leaderboard from "../components/Leaderboard.astro";
import { loadAthleteResults } from "../lib/athlete-loader";

const { hasLiveData } = loadAthleteResults();
---

<BaseLayout
  title="Leaderboard | Iron & Pine Omnium"
  description="Overall standings across women, men, and non-binary categories — ranked by combined moving time, sector performance, and KOM points."
>
  <main class="page-shell">
    <section class="section-dark leaderboard-page-wrap">
      <div class="section-inner">
        <div class="section-heading leaderboard-page-heading">
          <p class="eyebrow">Leaderboard</p>
          <span class:list={["status-badge", hasLiveData ? "status-live" : "status-pending"]}>
            {hasLiveData ? "Live results" : "Awaiting submissions"}
          </span>
          <h1 class="py-8">Overall Standings</h1>
          <p class="section-copy">
            {hasLiveData
              ? "Combined scores across both days, updated after each submission."
              : "The leaderboard will populate as riders submit their Strava activities."}
          </p>
        </div>
        <Leaderboard />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .leaderboard-page-wrap {
    min-height: 80vh;
    padding: clamp(3rem, 6vw, 5rem) var(--page-gutter);
    border-top: 3px solid var(--color-ember-400);
  }

  .leaderboard-page-heading h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
  }
</style>
