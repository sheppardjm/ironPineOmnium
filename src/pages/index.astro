---
import Leaderboard from "../components/Leaderboard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { defaultScoringConfig } from "../lib/scoring";

const eventLinks = [
  {
    label: "Day 1 · MK Ultra Gravel",
    href: "file:///Users/Sheppardjm/Repos/mkUltraGravel/dist/index.html",
    marker: "Fondo opener",
    vibe: "Long miles, rolling pace lines, and a moving-time benchmark that still bites.",
    detail: "An all-day fondo-style group ride where moving time matters without flattening the opener into a pure race.",
  },
  {
    label: "Day 2 · Hiawatha's Revenge",
    href: "file:///Users/Sheppardjm/Repos/hiawathasRevenge/dist/index.html",
    marker: "Grinduro closer",
    vibe: "Timed gravel sectors, climb points, and the selective day that settles the omnium.",
    detail: "A grinduro-style day across Alger and Marquette County where gravel sectors and KOM points decide the weekend.",
  },
];

const sceneSignals = [
  {
    title: "Dark hoodie weather",
    body: "Cold-start air, charcoal layers, and the kind of parking-lot atmosphere that feels better under cloud cover.",
  },
  {
    title: "Women set the tone",
    body: "The women’s field is treated like a real headliner here, with equal standing in the story and the scoring.",
  },
  {
    title: "Real omnium pressure",
    body: "One day stretches the group. One day detonates it. The table rewards whoever can carry form across both.",
  },
];

const gatheringNotes = [
  {
    title: "Pacific Northwest palette",
    body: "Deep fir greens, wet-stone neutrals, ember accents, and cream text that reads like a poster taped up in a bike shop window.",
  },
  {
    title: "More scene than expo",
    body: "The page now leans toward underground event-flyer energy instead of generic race brochure polish.",
  },
  {
    title: "Still grounded in the math",
    body: "The moody visuals do not replace the weekend logic. They frame the scoring system and the category-based leaderboard more clearly.",
  },
];

const terrainPanels = [
  {
    title: "Mist line",
    body: "Cold air hanging over fir tops, the kind of weather that makes the whole start grid feel quieter and more serious.",
    modifier: "terrain-card--mist",
  },
  {
    title: "Timber stand",
    body: "A straight-run forest corridor, wet grass under the trees, and the visual texture the page was missing.",
    modifier: "terrain-card--forest",
  },
  {
    title: "Cloud shelf",
    body: "Dark ridges and swallowed horizons so the event feels like it belongs outside, not just inside panels and type.",
    modifier: "terrain-card--ridge",
  },
];

const scoringPillars = [
  {
    title: "Day 1 moving time",
    weight: `${Math.round(defaultScoringConfig.day1Weight * 100)}%`,
    body: "Each rider is benchmarked against the fastest moving time in their category. The opener matters, but it does not overpower the rest of the weekend.",
  },
  {
    title: "Day 2 gravel sectors",
    weight: `${Math.round(defaultScoringConfig.sectorWeight * 100)}%`,
    body: "All timed gravel sectors are totaled, benchmarked against the fastest category aggregate, and weighted most heavily to reflect the grinduro pressure.",
  },
  {
    title: "Day 2 KOM points",
    weight: `${Math.round(defaultScoringConfig.komWeight * 100)}%`,
    body: "Climb points reward riders who race aggressively, even if they are not the absolute fastest across every gravel sector.",
  },
];
---

<BaseLayout
  title="Iron & Pine Omnium | Two Days of Gravel in the Hiawatha National Forest"
  description="A moody forest-night landing page for Iron & Pine Omnium, a two-day gravel series in Alger and Marquette County, Michigan."
>
  <main class="page-shell">
    <section class="hero-section">
      <div class="hero-copy">
        <p class="eyebrow">June 6 to 7, 2026 · Hiawatha National Forest</p>
        <p class="signal-chip">Pacific Northwest mood, Upper Peninsula dirt.</p>
        <h1 class="hero-title">Iron & Pine Omnium</h1>
        <p class="hero-kicker">
          A gravel weekend for dark hoodies, cold starts, and a women’s field that helps set the tone.
        </p>
        <p class="hero-body">
          Think mist, pine sap, camera flash, and a staging area that feels like a scene instead of a generic expo. Day one is a fondo-style group ride. Day two flips into timed sectors and KOM chases. Overall winners are still calculated separately for men, women, and non-binary riders.
        </p>

        <div class="cta-row">
          <a class="primary-button" href="#leaderboard">See the Omnium Leaderboard</a>
          <a class="secondary-button" href="#format">How the weekend works</a>
        </div>

        <div class="signal-grid">
          {sceneSignals.map((signal) => (
            <article class="signal-card">
              <h3>{signal.title}</h3>
              <p>{signal.body}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="hero-panel">
        <div class="hero-poster">
          <p class="poster-overline">Forest Flyer · 2026</p>
          <h2 class="poster-title">Fog in the lot. Fir shadows on the course. Two days to earn the table.</h2>

          <div class="poster-grid">
            <div>
              <span>Format</span>
              <strong>Fondo + Grinduro</strong>
            </div>
            <div>
              <span>Scoring</span>
              <strong>Moving time · sectors · KOM</strong>
            </div>
            <div>
              <span>Fields</span>
              <strong>Women · Men · Non-Binary</strong>
            </div>
          </div>

          <div class="route-stack">
            {eventLinks.map((event, index) => (
              <article class:list={{ "route-card": true, "route-card--ember": index === 1 }}>
                <p class="route-marker">{event.marker}</p>
                <h3>{event.label}</h3>
                <p class="route-vibe">{event.vibe}</p>
                <a class="inline-link" href={event.href}>Open companion site</a>
              </article>
            ))}
          </div>
        </div>

        <div class="badge-cluster" aria-hidden="true">
          <div class="floating-badge floating-badge--mist">Hoodie weather</div>
          <div class="floating-badge floating-badge--ember">Forest pressure</div>
          <div class="floating-badge floating-badge--fern">Women lead out</div>
        </div>
      </div>
    </section>

    <section class="content-section manifesto-section">
      <div class="section-heading">
        <p class="eyebrow">Scene Setting</p>
        <h2>Built like the flyer for the gravel weekend everybody wanted to be seen at.</h2>
        <p class="section-copy">
          This version keeps the Hiawatha terrain intact and shifts the visual language: darker, colder, more cinematic, and more specific about the culture around the ride. Less generic race brochure, more forest-night event identity.
        </p>
      </div>

      <div class="manifesto-grid">
        {gatheringNotes.map((note) => (
          <article class="manifesto-card">
            <h3>{note.title}</h3>
            <p>{note.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="terrain-section" aria-label="Landscape atmosphere">
      <div class="terrain-grid">
        {terrainPanels.map((panel) => (
          <article class:list={["terrain-card", panel.modifier]}>
            <div class="terrain-card__body">
              <p class="terrain-label">Outdoor note</p>
              <h3>{panel.title}</h3>
              <p>{panel.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="format" class="content-section">
      <div class="section-heading">
        <p class="eyebrow">Weekend Flow</p>
        <h2>Two linked ride days. One final ranking.</h2>
        <p class="section-copy">
          The opener establishes moving-time pressure without turning the weekend into a single stopwatch contest. The closer is where sectors and climbs sort the field.
        </p>
      </div>

      <div class="event-grid">
        {eventLinks.map((event, index) => (
          <article class="event-card">
            <p class="event-marker">{event.marker}</p>
            <h3>{event.label}</h3>
            <p class:list={{ "event-vibe": true, "event-vibe--ember": index === 1 }}>{event.vibe}</p>
            <p>{event.detail}</p>
            <a class="inline-link" href={event.href}>Visit companion site</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section scoring-section">
      <div class="section-heading">
        <p class="eyebrow">Scoring System</p>
        <h2>The mood is cinematic. The math stays blunt.</h2>
        <p class="section-copy">
          Fastest category benchmarks are normalized to 100, then weighted across the weekend. The visuals got moodier, but the logic remains strict and readable.
        </p>
      </div>

      <div class="pillar-grid">
        {scoringPillars.map((pillar) => (
          <article class="pillar-card">
            <div class="pill-row">
              <span class="score-pill">{pillar.weight}</span>
              <span class="mini-label">weighted contribution</span>
            </div>
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
          </article>
        ))}
      </div>

      <div class="formula-card">
        <p class="eyebrow">Formula</p>
        <p class="formula-text">
          Overall score = day 1 benchmark ratio × {Math.round(defaultScoringConfig.day1Weight * 100)} +
          day 2 sector benchmark ratio × {Math.round(defaultScoringConfig.sectorWeight * 100)} +
          KOM benchmark ratio × {Math.round(defaultScoringConfig.komWeight * 100)}
        </p>
        <p class="formula-note">
          Each category is ranked independently. The leaderboard below uses sample rider data so the model and UI can be validated before importing real results.
        </p>
      </div>
    </section>

    <section id="leaderboard" class="content-section leaderboard-section">
      <div class="section-heading">
        <p class="eyebrow">Leaderboard</p>
        <h2>Three categories. Three score inputs. One winner in each field.</h2>
        <p class="section-copy">
          The leaderboard below still runs on sample data, but the presentation now matches the event identity instead of dropping into a generic utility table.
        </p>
      </div>

      <Leaderboard />
    </section>

    <section class="content-section final-cta">
      <div>
        <p class="eyebrow">Open The Ride Pages</p>
        <h2>Start with the routes, then bring the results back to the omnium.</h2>
        <p class="section-copy">
          The individual event sites hold the ride-day details. This page is the shared poster, scoreboard, and weekend summary.
        </p>
      </div>
      <div class="cta-stack">
        {eventLinks.map((event) => (
          <a class="secondary-button w-full justify-center" href={event.href}>{event.label}</a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
