---
import PodiumPreview from "../components/PodiumPreview.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { defaultScoringConfig } from "../lib/scoring";
import { loadAthleteResults } from "../lib/athlete-loader";

const { hasLiveData } = loadAthleteResults();

const events = [
  {
    day: "Day 1",
    name: "Hiawatha's Revenge",
    marker: "Saturday",
    miles: "102",
    elevation: "2,258",
    description: "The fondo opens the weekend with the bigger miles. Moving time is counted toward the omnium overall.",
    site: "https://hiawathasrevenge.com",
    strava: "https://www.strava.com/routes/3476978085290434764",
    routeMap: "/images/route-mkultra.png",
  },
  {
    day: "Day 2",
    name: "MK Ultra Gravel",
    marker: "Sunday",
    miles: "100",
    elevation: "3,365",
    description: "Timed sectors and KOM climbs carry the heaviest scoring weight. This is where the table gets decided.",
    site: "https://mkultragravel.com",
    strava: "https://www.strava.com/routes/3474143305417209640",
    routeMap: "/images/route-hiawatha.png",
  },
];

const gatheringNotes = [
  {
    title: "Forest roads",
    body: "The route photos do most of the talking: pines, streams, hardpack, and chunky gravel.",
  },
  {
    title: "Simple weekend shape",
    body: "Two established 100-miler gravel grinders — one combined result.",
  },
  {
    title: "No pressure",
    body: "Ride your own ride. The scoring rewards those who work together.",
  },
];

const rideFrames = [
  {
    label: "Day 1 · Hiawatha's Revenge",
    title: "Pine-lined stretch",
    body: "Hiawatha opens the weekend with the longer forest-road miles.",
    src: "/images/hiawatha-riders.jpg",
    alt: "Two gravel cyclists riding on a pine-lined road during Hiawatha's Revenge.",
    modifier: "ride-frame--feature",
  },
  {
    label: "Day 1 · Forest Canopy",
    title: "Under the hardwoods",
    body: "Dappled light through a dense canopy tunnel.",
    src: "/images/canopy-tunnel.jpg",
    alt: "A gravel cyclist riding through a dense hardwood forest canopy.",
    modifier: "ride-frame--portrait",
  },
  {
    label: "Day 1 · Rough Surface",
    title: "Untamed surfaces",
    body: "A few rough stretches challenge rides both days.",
    src: "/images/hiawatha-rock-garden.jpg",
    alt: "A gravel bike on a rough, rock-strewn forest road during Hiawatha's Revenge.",
    modifier: "ride-frame--conditions",
  },
  {
    label: "Day 2 · MK Ultra Gravel",
    title: "Rolling start",
    body: "Sunday brings the timed sectors and sharper efforts through the forest.",
    src: "/images/mkultra-riders.jpg",
    alt: "Two gravel cyclists riding on a wooded road during MK Ultra Gravel.",
    modifier: "ride-frame--ride",
  },
  {
    label: "Day 2 · Conditions",
    title: "Wet section",
    body: "The route stays honest when the water sits on the road.",
    src: "/images/mkultra-puddle.jpg",
    alt: "Two gravel bikes laid beside a large puddle on a forest road during MK Ultra Gravel.",
    modifier: "ride-frame--conditions",
  },
  {
    label: "Day 2 · Open Road",
    title: "Farmland stretch",
    body: "The route opens up through rolling pasture between the forest sections.",
    src: "/images/farmland-road.jpg",
    alt: "A winding dirt road through green farmland under blue sky.",
    modifier: "ride-frame--portrait",
  },
  {
    label: "Day 2 · Views for days",
    title: "Two-up on sand",
    body: "Some epic view of Lake Superior near the end of the route.",
    src: "/images/two-riders-sandy.jpg",
    alt: "Two gravel cyclists riding abreast on a wide sandy road lined with trees.",
    modifier: "ride-frame--ride",
  },
  {
    label: "Day 1 · The Corridor",
    title: "Pine corridor",
    body: "Curving and quiet through the NFS pine stands.",
    src: "/images/spruce-corridor.jpg",
    alt: "A solo gravel cyclist riding a straight road through sparse spruce forest.",
    modifier: "ride-frame--portrait",
  },
];

const scoringPillars = [
  {
    title: "Day 1 moving time",
    weight: `${Math.round(defaultScoringConfig.movingTimeWeight * 100)}%`,
    body: "Each rider is benchmarked against the fastest moving time in their category. The fondo matters, but it does not overpower the rest of the weekend.",
  },
  {
    title: "Day 2 gravel sectors",
    weight: `${Math.round(defaultScoringConfig.sectorWeight * 100)}%`,
    body: "All timed gravel sectors are totaled, benchmarked against the fastest category aggregate, and weighted most heavily to reflect the grinduro pressure.",
  },
  {
    title: "Day 2 KOM points",
    weight: `${Math.round(defaultScoringConfig.komWeight * 100)}%`,
    body: "Climb points reward riders who race aggressively, even if they are not the absolute fastest across every gravel sector.",
  },
];
---

<BaseLayout
  title="Iron & Pine Omnium | Two Days of Gravel in the Hiawatha National Forest"
  description="A simple landing page for Iron & Pine Omnium, a two-day gravel weekend in Michigan's Upper Peninsula."
>
  <main class="page-shell">
    <section class="hero-section">
      <div class="hero-center">
        <img src="/logo.svg" alt="" width="72" height="54" class="hero-logo" />
        <p class="hero-dateline">June 6 – 7, 2026 · Hiawatha National Forest</p>
        <h1 class="hero-title">Iron &amp; Pine<br/>Omnium</h1>
        <p class="hero-kicker">
          Two days of gravel riding in the Upper Peninsula.
        </p>
        <div class="hero-ctas">
          <a class="primary-button" href="/leaderboard">Leaderboard</a>
          <a class="secondary-button" href="#format">How the weekend works</a>
        </div>
        <div class="hero-strip">
          <span>Fondo + Grinduro</span>
          <span class="hero-strip-dot" aria-hidden="true"></span>
          <span>Women · Men · Non-Binary</span>
          <span class="hero-strip-dot" aria-hidden="true"></span>
          <span>Moving time · Sectors · KOM</span>
        </div>
      </div>
    </section>

    <section id="format" class="content-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Weekend Flow</p>
          <h2>Start long, finish sharp.</h2>
          <p class="section-copy">
            The first day rewards steady riding and plenty of friendly stops across the fondo. The second day puts weight on timed sectors and climbing.
          </p>
        </div>

        <div class="event-grid">
          {events.map((event) => (
            <article class="event-card">
              <div class="event-card-body">
                <div class="event-head">
                  <span class="event-marker">{event.marker}</span>
                  <span class="event-day">{event.day}</span>
                </div>
                <h3 class="event-name">{event.name}</h3>
                <div class="event-stats">
                  <div class="event-stat">
                    <span class="event-stat-value">{event.miles}</span>
                    <span class="event-stat-label">Miles</span>
                  </div>
                  <div class="event-stat">
                    <span class="event-stat-value">{event.elevation}</span>
                    <span class="event-stat-label">Ft Climbing</span>
                  </div>
                </div>
                <p class="event-description">{event.description}</p>
                <div class="event-links">
                  <a class="inline-link" href={event.site}>Companion site</a>
                  <a class="inline-link strava-link" href={event.strava}><svg class="strava-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>Strava route</a>
                </div>
              </div>
              <a class="event-route-map" href={event.strava}>
                <img src={event.routeMap} alt={`${event.name} route overview`} loading="lazy" />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section scoring-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Scoring System</p>
          <h2>Straightforward scoring.</h2>
          <p class="section-copy">
            Each category is benchmarked against its fastest rider, then weighted across the weekend.
          </p>
        </div>

        <div class="scoring-strip">
          {scoringPillars.map((pillar) => (
            <div class="scoring-item">
              <span class="scoring-weight">{pillar.weight}</span>
              <div class="scoring-detail">
                <h3>{pillar.title}</h3>
                <p>{pillar.body}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="formula-bar">
          <p class="formula-text">
            Overall = moving time × {Math.round(defaultScoringConfig.movingTimeWeight * 100)} + sectors × {Math.round(defaultScoringConfig.sectorWeight * 100)} + KOM × {Math.round(defaultScoringConfig.komWeight * 100)}
          </p>
          <p class="formula-note">
            Each category is ranked independently.{hasLiveData
              ? " Live results from submitted activities."
              : " Results appear once riders begin submitting."}
          </p>
        </div>
      </div>
    </section>

    <section class="content-section manifesto-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">What To Expect</p>
          <h2>A simple two-day gravel weekend.</h2>
          <p class="section-copy">
            The first annual Iron & Pine Omnium is a two-day gravel weekend in Michigan's Hiawatha National Forest. The format is straightforward: a longer fondo on Saturday, followed by a day of timed sectors and KOMs on Sunday. Riders are scored virtually across both days for an overall result that rewards consistency, pacing, and endurance.
          </p>
        </div>

        <div class="manifesto-strip">
          {gatheringNotes.map((note, i) => (
            <div class="manifesto-item">
              <span class="manifesto-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3>{note.title}</h3>
                <p>{note.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="ride-reel-section" aria-label="Ride photography from the event routes">
      <div class="section-inner ride-reel-inner">
        <div class="section-heading ride-reel-heading">
          <p class="eyebrow">From The Route</p>
          <h2>The roads speak for themselves.</h2>
          <p class="section-copy">
            Hardpack, loose rock, and the occasional standing water. Two days on forest roads in the Hiawatha National Forest.
          </p>
        </div>

        <div class="ride-reel-grid">
          {rideFrames.map((frame) => (
            <figure class:list={["ride-frame", frame.modifier]}>
              <img src={frame.src} alt={frame.alt} loading="lazy" decoding="async" />
              <figcaption class="ride-frame__body">
                <p class="ride-frame__label">{frame.label}</p>
                <h3>{frame.title}</h3>
                <p>{frame.body}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="submit-banner section-dark">
      <div class="submit-banner-inner">
        <p class="eyebrow">Ready?</p>
        <h2>Submit Your Results</h2>
        <p>Connect your Strava account and paste your activity URL to land on the leaderboard.</p>
        <a class="primary-button" href="/submit">Submit Results</a>
      </div>
    </section>

    <section id="leaderboard" class="content-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Leaderboard</p>
          <span class:list={["status-badge", hasLiveData ? "status-live" : "status-pending"]}>
            {hasLiveData ? "Live results" : "Awaiting submissions"}
          </span>
          <h2>{hasLiveData ? "Current standings." : "Awaiting submissions."}</h2>
          <p class="section-copy">
            {hasLiveData
              ? "Top finishers across both days."
              : "The leaderboard will populate as riders submit their Strava activities."}
          </p>
        </div>

        <PodiumPreview />
      </div>
    </section>

    <section class="content-section companion-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Companion Sites</p>
          <h2>See each day on its own.</h2>
          <p class="section-copy">
            Route details and ride-day specifics live on the two event sites.
          </p>
        </div>
        <div class="companion-grid">
          {events.map((event) => (
            <a class="companion-card" href={event.site}>
              <span class="companion-marker">{event.marker}</span>
              <span class="companion-name">{event.day} · {event.name}</span>
              <span class="companion-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
