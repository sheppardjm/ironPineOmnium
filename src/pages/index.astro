---
import Leaderboard from "../components/Leaderboard.astro";
import LogoMark from "../components/LogoMark.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { defaultScoringConfig } from "../lib/scoring";
import { loadAthleteResults } from "../lib/athlete-loader";

const { hasLiveData } = loadAthleteResults();

const eventLinks = [
  {
    label: "Day 1 · Hiawatha's Revenge",
    href: "file:///Users/Sheppardjm/Repos/hiawathasRevenge/dist/index.html",
    marker: "Saturday",
    vibe: "Long fondo day with moving time counted toward the overall.",
    detail: "Hiawatha's Revenge opens the weekend with the bigger miles and sets the baseline for the omnium.",
  },
  {
    label: "Day 2 · MK Ultra Gravel",
    href: "file:///Users/Sheppardjm/Repos/mkUltraGravel/dist/index.html",
    marker: "Sunday",
    vibe: "Timed sectors and KOM points decide more of the table.",
    detail: "MK Ultra Gravel closes the weekend with the sharper efforts and carries the heaviest scoring weight.",
  },
];

const sceneSignals = [
  {
    title: "Saturday ride",
    body: "Start with distance and moving time on the fondo.",
  },
  {
    title: "Sunday push",
    body: "Finish with timed sectors, climbs, and a harder sort.",
  },
  {
    title: "Separate standings",
    body: "Women, men, and non-binary riders each get their own overall table.",
  },
];

const gatheringNotes = [
  {
    title: "Forest roads",
    body: "The route photos do most of the talking: pines, water, hardpack, and loose rock.",
  },
  {
    title: "Simple weekend shape",
    body: "Two established events, one combined result, and an easy page to check between ride days.",
  },
  {
    title: "Stay around",
    body: "It should feel like a ride weekend people want to hang around for, not just race through.",
  },
];

const rideFrames = [
  {
    label: "Day 1 · Hiawatha's Revenge",
    title: "Pine-lined stretch",
    body: "Hiawatha opens the weekend with the longer forest-road miles.",
    src: "/images/hiawatha-riders.jpg",
    alt: "Two gravel cyclists riding on a pine-lined road during Hiawatha's Revenge.",
    modifier: "ride-frame--feature",
  },
  {
    label: "Day 1 · Rough Surface",
    title: "Loose rock",
    body: "The rougher surface shows up early in the weekend.",
    src: "/images/hiawatha-rock-garden.jpg",
    alt: "A gravel bike on a rough, rock-strewn forest road during Hiawatha's Revenge.",
    modifier: "ride-frame--conditions",
  },
  {
    label: "Day 2 · MK Ultra Gravel",
    title: "Rolling start",
    body: "Sunday brings the timed sectors and sharper efforts through the forest.",
    src: "/images/mkultra-riders.jpg",
    alt: "Two gravel cyclists riding on a wooded road during MK Ultra Gravel.",
    modifier: "ride-frame--ride",
  },
  {
    label: "Day 2 · Conditions",
    title: "Wet section",
    body: "The route stays honest when the water sits on top of the road.",
    src: "/images/mkultra-puddle.jpg",
    alt: "Two gravel bikes laid beside a large puddle on a forest road during MK Ultra Gravel.",
    modifier: "ride-frame--conditions",
  },
];

const scoringPillars = [
  {
    title: "Day 1 moving time",
    weight: `${Math.round(defaultScoringConfig.movingTimeWeight * 100)}%`,
    body: "Each rider is benchmarked against the fastest moving time in their category. The fondo matters, but it does not overpower the rest of the weekend.",
  },
  {
    title: "Day 2 gravel sectors",
    weight: `${Math.round(defaultScoringConfig.sectorWeight * 100)}%`,
    body: "All timed gravel sectors are totaled, benchmarked against the fastest category aggregate, and weighted most heavily to reflect the grinduro pressure.",
  },
  {
    title: "Day 2 KOM points",
    weight: `${Math.round(defaultScoringConfig.komWeight * 100)}%`,
    body: "Climb points reward riders who race aggressively, even if they are not the absolute fastest across every gravel sector.",
  },
];
---

<BaseLayout
  title="Iron & Pine Omnium | Two Days of Gravel in the Hiawatha National Forest"
  description="A simple landing page for Iron & Pine Omnium, a two-day gravel weekend in Michigan's Upper Peninsula."
>
  <main class="page-shell">
    <section class="hero-section">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">June 6 to 7, 2026 · Hiawatha National Forest</p>
          <div class="logo-lockup">
            <LogoMark class="logo-mark" />
            <div class="logo-copy">
              <p class="logo-subtitle">Two-day gravel omnium</p>
              <h1 class="hero-title">Iron & Pine Omnium</h1>
            </div>
          </div>
          <p class="hero-kicker">
            Two days of gravel riding in the Upper Peninsula.
          </p>
          <p class="hero-body">
            Saturday starts with Hiawatha&apos;s Revenge and its moving time counted toward the overall. Sunday finishes at MK Ultra Gravel with timed sectors and KOM points. The omnium keeps separate overall standings for women, men, and non-binary riders.
          </p>

          <div class="cta-row">
            <a class="primary-button" href="#leaderboard">See the Omnium Leaderboard</a>
            <a class="secondary-button" href="#format">How the weekend works</a>
          </div>

          <div class="signal-grid">
            {sceneSignals.map((signal) => (
              <article class="signal-card">
                <h3>{signal.title}</h3>
                <p>{signal.body}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="hero-panel">
          <div class="hero-poster">
            <p class="poster-overline">Weekend overview</p>
            <h2 class="poster-title">Ride Saturday. Push Sunday. Add it up at the end.</h2>

            <div class="poster-grid">
              <div>
                <span>Format</span>
                <strong>Fondo + Grinduro</strong>
              </div>
              <div>
                <span>Scoring</span>
                <strong>Moving time · sectors · KOM</strong>
              </div>
              <div>
                <span>Fields</span>
                <strong>Women · Men · Non-Binary</strong>
              </div>
            </div>

            <div class="route-stack">
              {eventLinks.map((event) => (
                <article class="route-card">
                  <p class="route-marker">{event.marker}</p>
                  <h3>{event.label}</h3>
                  <p class="route-vibe">{event.vibe}</p>
                  <a class="inline-link" href={event.href}>Open companion site</a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section manifesto-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">What To Expect</p>
          <h2>A simple page for a two-day ride weekend.</h2>
          <p class="section-copy">
            The companion sites carry the route details. This page keeps the overview, the combined scoring, and photos that actually show the roads.
          </p>
        </div>

        <div class="manifesto-grid">
          {gatheringNotes.map((note) => (
            <article class="manifesto-card">
              <h3>{note.title}</h3>
              <p>{note.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="ride-reel-section" aria-label="Ride photography from the event routes">
      <div class="section-inner ride-reel-inner">
        <div class="section-heading ride-reel-heading">
          <p class="eyebrow">From The Route</p>
          <h2>Photos from both days.</h2>
          <p class="section-copy">
            Pulled directly from the MK Ultra Gravel and Hiawatha&apos;s Revenge sites.
          </p>
        </div>

        <div class="ride-reel-grid">
          {rideFrames.map((frame) => (
            <figure class:list={["ride-frame", frame.modifier]}>
              <img src={frame.src} alt={frame.alt} loading="lazy" decoding="async" />
              <figcaption class="ride-frame__body">
                <p class="ride-frame__label">{frame.label}</p>
                <h3>{frame.title}</h3>
                <p>{frame.body}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="format" class="content-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Weekend Flow</p>
          <h2>Start sharp, finish long.</h2>
          <p class="section-copy">
            The first day rewards steady riding across the fondo. The second day puts weight on timed sectors and climbing.
          </p>
        </div>

        <div class="event-grid">
          {eventLinks.map((event) => (
            <article class="event-card">
              <p class="event-marker">{event.marker}</p>
              <h3>{event.label}</h3>
              <p class="event-vibe">{event.vibe}</p>
              <p>{event.detail}</p>
              <a class="inline-link" href={event.href}>Visit companion site</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section scoring-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Scoring System</p>
          <h2>Straightforward scoring.</h2>
          <p class="section-copy">
            Each category is benchmarked against its fastest rider, then weighted across the weekend.
          </p>
        </div>

        <div class="pillar-grid">
          {scoringPillars.map((pillar) => (
            <article class="pillar-card">
              <div class="pill-row">
                <span class="score-pill">{pillar.weight}</span>
                <span class="mini-label">weighted contribution</span>
              </div>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </article>
          ))}
        </div>

        <div class="formula-card">
          <p class="eyebrow">Formula</p>
          <p class="formula-text">
            Overall score = moving time ratio × {Math.round(defaultScoringConfig.movingTimeWeight * 100)} +
            sector ratio × {Math.round(defaultScoringConfig.sectorWeight * 100)} +
            KOM ratio × {Math.round(defaultScoringConfig.komWeight * 100)}
          </p>
          <p class="formula-note">
            Each category is ranked independently.{hasLiveData
              ? " The leaderboard below shows live results from submitted activities."
              : " The leaderboard will show results once riders begin submitting."}
          </p>
        </div>
      </div>
    </section>

    <section id="leaderboard" class="content-section leaderboard-section">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Leaderboard</p>
          <span class:list={["status-badge", hasLiveData ? "status-live" : "status-pending"]}>
            {hasLiveData ? "Live results" : "Awaiting submissions"}
          </span>
          <h2>{hasLiveData ? "Current standings." : "Awaiting submissions."}</h2>
          <p class="section-copy">
            {hasLiveData
              ? "Combined scores across both days, updated after each submission."
              : "The leaderboard will populate as riders submit their Strava activities."}
          </p>
        </div>

        <Leaderboard />
      </div>
    </section>

    <section class="content-section final-cta">
      <div class="section-inner final-cta__inner">
        <div>
          <p class="eyebrow">Ride Pages</p>
          <h2>See each day on its own.</h2>
          <p class="section-copy">
            Route details and ride-day specifics live on the two event sites.
          </p>
        </div>
        <div class="cta-stack">
          {eventLinks.map((event) => (
            <a class="secondary-button w-full justify-center" href={event.href}>{event.label}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
