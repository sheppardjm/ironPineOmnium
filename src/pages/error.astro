---
// error.astro — OAuth failure landing page
// Reads the `reason` query param client-side (project is static output mode,
// so Astro.url.searchParams is not available at runtime). A minimal inline
// script maps reason codes to user-friendly messages and updates the DOM.

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Connection Error | Iron & Pine Omnium"
  description="Something went wrong during the Strava connection. You can try again or return home."
>
  <main class="page-shell">
    <div class="error-shell">
      <div class="error-card">
        <p class="eyebrow" aria-hidden="true">Strava OAuth</p>
        <h1 class="error-heading">Connection Error</h1>
        <p class="error-message" id="error-message">
          Something went wrong during the Strava connection.
        </p>
        <div class="error-actions">
          <a class="primary-button" href="/api/strava-auth">Try Again</a>
          <a class="secondary-button" href="/">Back to Home</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Map OAuth failure reason codes to user-friendly messages.
    // Runs client-side because this is a static Astro site (no SSR).
    const messages: Record<string, string> = {
      strava_denied:
        "You declined the Strava authorization. We need access to your activity data to verify your ride and compute your score.",
      csrf_mismatch:
        "Your authorization session expired or was invalid. This can happen if you waited too long or opened multiple tabs.",
      token_exchange_failed:
        "We couldn't complete the connection to Strava. This is usually temporary.",
      insufficient_scope:
        "We need the 'View your activity data' permission to read your ride details. Without it, we can't compute your score.",
    };

    const params = new URLSearchParams(window.location.search);
    const reason = params.get("reason") ?? "";
    const el = document.getElementById("error-message");
    if (el && reason) {
      el.textContent =
        messages[reason] ??
        "Something went wrong during the Strava connection.";
    }
  </script>

  <style>
    .error-shell {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: var(--page-gutter, 1.5rem);
    }

    .error-card {
      position: relative;
      z-index: 1;
      max-width: 36rem;
      width: 100%;
      background: var(--color-fir-900, #17231f);
      border: 1px solid var(--color-fir-700, #2f463d);
      border-radius: 0.75rem;
      padding: clamp(2rem, 6vw, 3.5rem);
      box-shadow: var(--shadow-poster);
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .error-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 2.75rem);
      font-weight: 600;
      color: var(--color-mist-50);
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .error-message {
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.65;
      color: var(--color-mist-200, #d1cabd);
    }

    .error-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    /* Reuse global button styles if present; define fallbacks here */
    .primary-button {
      display: inline-flex;
      align-items: center;
      padding: 0.65rem 1.4rem;
      background: var(--color-ember-400, #dd8258);
      color: var(--color-night-975, #060908);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 600;
      border-radius: 0.375rem;
      text-decoration: none;
      transition: background 0.15s ease;
    }

    .primary-button:hover {
      background: var(--color-ember-500, #bc5f40);
    }

    .secondary-button {
      display: inline-flex;
      align-items: center;
      padding: 0.65rem 1.4rem;
      background: transparent;
      color: var(--color-mist-50);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 500;
      border: 1px solid var(--color-fern-500, #6d8977);
      border-radius: 0.375rem;
      text-decoration: none;
      transition: border-color 0.15s ease, color 0.15s ease;
    }

    .secondary-button:hover {
      border-color: var(--color-mist-200, #d1cabd);
      color: var(--color-mist-200, #d1cabd);
    }

    /* eyebrow label reusing global pattern */
    .eyebrow {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-fern-500, #6d8977);
    }
  </style>
</BaseLayout>
