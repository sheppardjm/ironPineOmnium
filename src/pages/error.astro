---
// error.astro — OAuth failure landing page
// Reads the `reason` query param client-side (project is static output mode,
// so Astro.url.searchParams is not available at runtime). A minimal inline
// script maps reason codes to user-friendly messages and updates the DOM.

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Connection Error | Iron & Pine Omnium"
  description="Something went wrong during the Strava connection. You can try again or return home."
>
  <main class="page-shell">
    <div class="error-shell">
      <div class="error-card">
        <img src="/logo.svg" alt="" width="64" height="48" style="opacity: 0.6; margin-bottom: 1.5rem;" />
        <p class="error-eyebrow">Connection Error</p>
        <h1 class="error-heading">Something went wrong</h1>
        <p class="error-message" id="error-message">
          Something went wrong during the Strava connection.
        </p>
        <div class="error-actions">
          <a class="primary-button" href="/api/strava-auth">Connect with Strava Again</a>
          <a class="secondary-button" href="/">Back to Home</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Map OAuth failure reason codes to user-friendly messages.
    // Runs client-side because this is a static Astro site (no SSR).
    const messages: Record<string, string> = {
      strava_denied:
        "You declined the Strava authorization. We need access to your activity data to verify your ride and compute your score.",
      csrf_mismatch:
        "Your authorization session expired or was invalid. This can happen if you waited too long or opened multiple tabs.",
      token_exchange_failed:
        "We couldn't complete the connection to Strava. This is usually temporary.",
      insufficient_scope:
        "We need the 'View your activity data' permission to read your ride details. Without it, we can't compute your score.",
    };

    const params = new URLSearchParams(window.location.search);
    const reason = params.get("reason") ?? "";
    const el = document.getElementById("error-message");
    if (el && reason) {
      el.textContent =
        messages[reason] ??
        "Something went wrong during the Strava connection.";
    }
  </script>

  <style>
    .error-shell {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 80vh;
      padding: var(--page-gutter);
    }

    .error-card {
      max-width: 32rem;
      width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .error-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ember-500);
    }

    .error-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: var(--color-night-900);
      line-height: 0.92;
      letter-spacing: -0.04em;
    }

    .error-message {
      font-family: var(--font-sans);
      font-size: 1.05rem;
      line-height: 1.65;
      color: var(--color-ink-muted);
      max-width: 36ch;
    }

    .error-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
      justify-content: center;
    }

    /* Secondary button — light mode, centered layout */
    .secondary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.65rem 1.4rem;
      background: transparent;
      color: var(--color-night-900);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 500;
      border: 1px solid rgba(19, 28, 26, 0.2);
      border-radius: 999px;
      text-decoration: none;
      transition: border-color 0.15s ease;
    }

    .secondary-button:hover {
      border-color: var(--color-night-900);
    }
  </style>
</BaseLayout>
