---
// submit-confirm.astro — Activity confirmation and identity page
// Decodes the base64url payload from ?payload= query param, renders a score
// preview with inline explanations, and collects rider identity (name + category).
// Static output mode: payload decode and rendering happen client-side.

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Confirm Submission | Iron & Pine Omnium"
  description="Review your activity score preview and confirm your submission to the Iron & Pine Omnium leaderboard."
  noindex={true}
>
  <main class="split-shell">
    <div class="split-brand split-brand--photo split-brand--confirm">
      <div class="brand-inner">
        <img src="/logo.svg" alt="" width="72" height="54" class="brand-logo" />
        <p class="brand-label">Iron & Pine Omnium</p>
        <h2 class="brand-title">Confirm Your Submission</h2>
        <p class="brand-body">
          Review your score preview, fill in your details, and submit to the leaderboard.
        </p>
      </div>
    </div>

    <div class="split-form">
      <div class="form-inner">
        <h1 class="form-title">Review your activity</h1>
        <p class="athlete-identity" id="athlete-identity"></p>
        <p class="confirm-date" id="activity-date"></p>

        <div class="score-preview" id="score-preview">
          <h2 class="preview-heading">Score Preview</h2>
          <div class="preview-grid">
            <div id="day1-preview"></div>
            <div id="sectors-preview"></div>
            <div id="kom-preview"></div>
          </div>
          <p class="preview-note">
            Final scores are computed relative to other riders in your category after all submissions close.
          </p>
        </div>

        <form id="confirm-form">
          <div class="form-field">
            <label for="rider-name">Display name</label>
            <input
              type="text"
              name="name"
              id="rider-name"
              required
              autocomplete="name"
              placeholder="How you want to appear on the leaderboard"
            />
          </div>
          <div class="form-field">
            <label for="rider-category">Category</label>
            <select name="category" id="rider-category" required>
              <option value="">Select your category</option>
              <option value="men">Men</option>
              <option value="women">Women</option>
              <option value="non-binary">Non-Binary</option>
            </select>
          </div>

          <!-- Hidden fields to carry payload data into Phase 7 submit-result POST -->
          <input type="hidden" name="activityId" id="h-activityId" />
          <input type="hidden" name="athleteId" id="h-athleteId" />
          <input type="hidden" name="movingTimeSeconds" id="h-movingTimeSeconds" />
          <input type="hidden" name="startDateLocal" id="h-startDateLocal" />
          <input type="hidden" name="sectorEfforts" id="h-sectorEfforts" />
          <input type="hidden" name="komSegmentIds" id="h-komSegmentIds" />
          <input type="hidden" name="komEfforts" id="h-komEfforts" />

          <div class="form-actions">
            <button type="submit" class="primary-button" id="confirm-btn">
              Confirm Submission
            </button>
            <a href="/submit" class="secondary-button">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    // Decode base64url-encoded payload from query string.
    // Encoding is the inverse of btoa() with +→- /→_ =→(removed) used in submit.astro.
    function fromBase64url(encoded: string): Record<string, unknown> {
      let b = encoded.replace(/-/g, "+").replace(/_/g, "/");
      while (b.length % 4) b += "=";
      return JSON.parse(atob(b));
    }

    // Format total seconds as HH:MM:SS — mirrors scoring.ts formatDuration.
    function formatTime(totalSeconds: number): string {
      const h = Math.floor(totalSeconds / 3600);
      const m = Math.floor((totalSeconds % 3600) / 60);
      const s = totalSeconds % 60;
      return [h, m, s].map((v) => String(v).padStart(2, "0")).join(":");
    }

    type Payload = {
      activityId?: string | number;
      athleteId?: string | number;
      athleteFirstname?: string;
      athleteLastname?: string;
      movingTimeSeconds?: number;
      startDateLocal?: string;
      sectorEfforts?: Record<string, number>;
      komSegmentIds?: string[];
      komEfforts?: Record<string, number>;
    };

    function renderPreview(payload: Payload): void {
      // Strava identity display
      const identityEl = document.getElementById("athlete-identity");
      if (identityEl) {
        const first = (payload.athleteFirstname ?? "").trim();
        const last = (payload.athleteLastname ?? "").trim();
        const fullName = [first, last].filter(Boolean).join(" ");
        if (fullName) {
          identityEl.textContent = "Connected as " + fullName;
        } else {
          identityEl.textContent = "Connected as Athlete #" + (payload.athleteId ?? "unknown");
        }
      }

      // Date display
      const dateEl = document.getElementById("activity-date");
      if (dateEl) {
        const date = payload.startDateLocal ?? "";
        if (date.startsWith("2026-06-06")) {
          dateEl.textContent = "Day 1 — Saturday, June 6";
        } else if (date.startsWith("2026-06-07")) {
          dateEl.textContent = "Day 2 — Sunday, June 7";
        } else {
          dateEl.textContent = date ? date.slice(0, 10) : "";
        }
      }

      // Moving time preview (35% weight) — Day 1 / Hiawatha's Revenge
      const day1El = document.getElementById("day1-preview");
      if (day1El) {
        const movingTime = payload.movingTimeSeconds ?? 0;
        if (movingTime > 0) {
          day1El.innerHTML = `
            <p class="preview-label">Day 1 · Moving Time</p>
            <p class="preview-value">${formatTime(movingTime)}</p>
            <p class="preview-explain">Your moving time counts for <strong>35%</strong> of your overall score, benchmarked against the fastest rider in your category.</p>
          `;
        } else {
          day1El.innerHTML = `
            <p class="preview-label">Day 1 · Moving Time</p>
            <p class="preview-value">—</p>
            <p class="preview-explain">Not applicable for Day 2 activities.</p>
          `;
        }
      }

      // Sectors preview (45% weight) — Day 2 / MK Ultra
      const sectorsEl = document.getElementById("sectors-preview");
      if (sectorsEl) {
        const sectorEfforts = payload.sectorEfforts ?? {};
        const sectorCount = Object.keys(sectorEfforts).length;
        const sectorTotal = Object.values(sectorEfforts).reduce(
          (a: number, b: number) => a + b,
          0
        );
        if (sectorCount > 0) {
          sectorsEl.innerHTML = `
            <p class="preview-label">Day 2 · Timed Sectors</p>
            <p class="preview-value">${sectorCount} of 7 sectors · ${formatTime(sectorTotal)}</p>
            <p class="preview-explain">Your combined sector time counts for <strong>45%</strong> of your overall score, benchmarked against the fastest aggregate in your category.</p>
          `;
        } else {
          const isDay2 = payload.startDateLocal === "2026-06-07";
          if (isDay2) {
            sectorsEl.innerHTML = `
              <div class="zero-match-warning">
                <p class="preview-label">Day 2 · Timed Sectors</p>
                <p class="preview-value warning-value">0 of 7 sectors matched</p>
                <p class="preview-explain warning-explain">This activity had no recognized timed sectors. Your Day 2 sector score will be zero (45% of your overall score). This is unusual — double-check that you submitted the correct MK Ultra Gravel activity.</p>
              </div>
            `;
          } else {
            sectorsEl.innerHTML = `
              <p class="preview-label">Day 2 · Timed Sectors</p>
              <p class="preview-value">—</p>
              <p class="preview-explain">Not applicable for Day 1 activities.</p>
            `;
          }
        }
      }

      // KOM preview (20% weight) — Day 2 / MK Ultra
      const komEl = document.getElementById("kom-preview");
      if (komEl) {
        const komCount = (payload.komSegmentIds ?? []).length;
        const komEfforts = payload.komEfforts ?? {};
        const komTimeTotal = Object.values(komEfforts).reduce(
          (a: number, b: number) => a + b, 0
        );
        if (komCount > 0) {
          const timeDisplay = komTimeTotal > 0
            ? ` · ${formatTime(komTimeTotal)} total climb time`
            : "";
          komEl.innerHTML = `
            <p class="preview-label">Day 2 · KOM Points</p>
            <p class="preview-value">${komCount} of 3 KOM segments${timeDisplay}</p>
            <p class="preview-explain">KOM points count for <strong>20%</strong> of your overall score, based on how your climb times compare to other riders.</p>
          `;
        } else {
          const isDay2 = payload.startDateLocal === "2026-06-07";
          if (isDay2) {
            komEl.innerHTML = `
              <div class="zero-match-warning">
                <p class="preview-label">Day 2 · KOM Points</p>
                <p class="preview-value warning-value">0 of 3 KOM segments matched</p>
                <p class="preview-explain warning-explain">No KOM climb segments were found in this activity. Your KOM score will be zero (20% of your overall score).</p>
              </div>
            `;
          } else {
            komEl.innerHTML = `
              <p class="preview-label">Day 2 · KOM Points</p>
              <p class="preview-value">—</p>
              <p class="preview-explain">Not applicable for Day 1 activities.</p>
            `;
          }
        }
      }
    }

    function populateHiddenFields(payload: Payload): void {
      const set = (id: string, value: unknown) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) {
          el.value =
            typeof value === "object" ? JSON.stringify(value) : String(value ?? "");
        }
      };
      set("h-activityId", payload.activityId);
      set("h-athleteId", payload.athleteId);
      set("h-movingTimeSeconds", payload.movingTimeSeconds);
      set("h-startDateLocal", payload.startDateLocal);
      set("h-sectorEfforts", payload.sectorEfforts ?? {});
      set("h-komSegmentIds", payload.komSegmentIds ?? []);
      set("h-komEfforts", payload.komEfforts ?? {});
    }

    function setupForm(): void {
      const form = document.getElementById("confirm-form") as HTMLFormElement;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const nameInput = document.getElementById("rider-name") as HTMLInputElement;
        const categorySelect = document.getElementById(
          "rider-category"
        ) as HTMLSelectElement;
        const name = nameInput.value.trim();
        const category = categorySelect.value;

        // Reset custom validity before re-checking
        nameInput.setCustomValidity("");
        categorySelect.setCustomValidity("");

        if (!name) {
          nameInput.setCustomValidity("Please enter your display name.");
          nameInput.reportValidity();
          return;
        }

        if (!category) {
          categorySelect.setCustomValidity("Please select your category.");
          categorySelect.reportValidity();
          return;
        }

        // Disable button and show submitting state
        const btn = document.getElementById("confirm-btn") as HTMLButtonElement;
        btn.textContent = "Submitting...";
        btn.disabled = true;

        // Collect form data from hidden inputs
        const formEl = document.getElementById("confirm-form") as HTMLFormElement;
        const fd = new FormData(formEl);

        const payload = {
          name: name,
          category: category,
          activityId: fd.get("activityId"),
          athleteId: fd.get("athleteId"),
          movingTimeSeconds: Number(fd.get("movingTimeSeconds")),
          startDateLocal: fd.get("startDateLocal"),
          sectorEfforts: JSON.parse((fd.get("sectorEfforts") as string) || "{}"),
          komSegmentIds: JSON.parse((fd.get("komSegmentIds") as string) || "[]"),
          komEfforts: JSON.parse((fd.get("komEfforts") as string) || "{}"),
        };

        try {
          const res = await fetch("/api/submit-result", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
            credentials: "include",
          });

          const result = await res.json();

          if (result.ok) {
            // Redirect to homepage with submitted flag
            window.location.href = "/?submitted=true";
            return;
          }

          // Show error and re-enable button
          btn.textContent = "Confirm Submission";
          btn.disabled = false;

          const errorMap: Record<string, string> = {
            athlete_mismatch: "Session mismatch — please sign in again.",
            invalid_payload: "Missing required fields. Please try again.",
            invalid_date: "Activity date is outside the event window.",
            write_conflict: "Temporary conflict — please try again.",
            github_error: "Server error — please try again in a moment.",
            github_write_error: "Failed to save — please try again.",
          };

          const msg = errorMap[result.error] || "Something went wrong. Please try again.";
          alert(msg);

        } catch (_err) {
          btn.textContent = "Confirm Submission";
          btn.disabled = false;
          alert("Network error — please check your connection and try again.");
        }
      });

      // Clear custom validity on interaction to allow re-submission attempts
      (document.getElementById("rider-name") as HTMLInputElement).addEventListener(
        "input",
        function (this: HTMLInputElement) {
          this.setCustomValidity("");
        }
      );
      (
        document.getElementById("rider-category") as HTMLSelectElement
      ).addEventListener("change", function (this: HTMLSelectElement) {
        this.setCustomValidity("");
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      const params = new URLSearchParams(window.location.search);
      const encoded = params.get("payload");

      if (!encoded) {
        window.location.href = "/submit";
        return;
      }

      let payload: Payload;
      try {
        payload = fromBase64url(encoded) as Payload;
      } catch (_) {
        window.location.href = "/submit";
        return;
      }

      renderPreview(payload);
      populateHiddenFields(payload);
      setupForm();
    });
  </script>

  <style>
    .brand-inner {
      max-width: 24rem;
    }

    .brand-logo {
      margin-bottom: 2rem;
      filter: invert(1) brightness(1.05) sepia(0.12) saturate(0.5);
      opacity: 0.85;
    }

    .brand-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-mist-400);
    }

    .brand-title {
      margin-top: 0.5rem;
      font-family: var(--font-display);
      font-size: clamp(2rem, 7vw, 4.5rem);
      font-weight: 700;
      color: var(--color-mist-50);
      line-height: 1.05;
      letter-spacing: -0.045em;
    }

    .brand-body {
      margin-top: 1.25rem;
      font-size: 1.05rem;
      line-height: 1.65;
      color: var(--color-mist-200);
      max-width: 30ch;
    }

    .form-inner {
      max-width: 32rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .form-title {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: var(--color-night-900);
      line-height: 0.92;
      letter-spacing: -0.04em;
    }

    .athlete-identity {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--color-ink-muted);
    }

    .confirm-date {
      font-family: var(--font-sans);
      font-size: 1rem;
      color: var(--color-ember-400);
      font-weight: 700;
    }

    /* Score preview */
    .preview-heading {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      margin-bottom: 0.75rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--color-ember-400);
    }

    .preview-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(19, 28, 26, 0.08);
    }

    @media (min-width: 640px) {
      .preview-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .preview-grid > div {
      background: var(--color-surface, #f5f0e8);
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .preview-label {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      margin: 0;
    }

    .preview-value {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--color-night-900);
      line-height: 1.2;
      margin: 0;
    }

    .preview-explain {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--color-ink-muted);
      margin: 0;
    }

    .preview-explain strong {
      color: var(--color-ember-400);
    }

    .preview-note {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--color-mist-400);
      font-style: italic;
      margin-top: 0.75rem;
    }

    .zero-match-warning {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .warning-value {
      color: var(--color-ember-400) !important;
    }

    .warning-explain {
      color: var(--color-ember-400) !important;
      opacity: 0.85;
    }

    /* Form */
    #confirm-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
  </style>
</BaseLayout>
