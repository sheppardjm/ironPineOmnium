---
// submit-confirm.astro — Activity confirmation and identity page
// Decodes the base64url payload from ?payload= query param, renders a score
// preview with inline explanations, and collects rider identity (name + category).
// Static output mode: payload decode and rendering happen client-side.

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Confirm Submission | Iron & Pine Omnium"
  description="Review your activity score preview and confirm your submission to the Iron & Pine Omnium leaderboard."
>
  <main class="page-shell">
    <div class="confirm-shell">
      <div class="confirm-card">
        <p class="eyebrow" aria-hidden="true">Confirm Submission</p>
        <h1 class="confirm-heading">Review your activity</h1>
        <p class="confirm-date" id="activity-date"></p>

        <div class="score-preview" id="score-preview">
          <h2 class="preview-heading">Score Preview</h2>
          <div class="preview-grid">
            <div id="day1-preview"></div>
            <div id="sectors-preview"></div>
            <div id="kom-preview"></div>
          </div>
          <p class="preview-note">
            Final scores are computed relative to other riders in your category after all submissions close.
          </p>
        </div>

        <form id="confirm-form">
          <div class="form-field">
            <label for="rider-name">Display name</label>
            <input
              type="text"
              name="name"
              id="rider-name"
              required
              autocomplete="name"
              placeholder="How you want to appear on the leaderboard"
            />
          </div>
          <div class="form-field">
            <label for="rider-category">Category</label>
            <select name="category" id="rider-category" required>
              <option value="">Select your category</option>
              <option value="men">Men</option>
              <option value="women">Women</option>
              <option value="non-binary">Non-Binary</option>
            </select>
          </div>

          <!-- Hidden fields to carry payload data into Phase 7 submit-result POST -->
          <input type="hidden" name="activityId" id="h-activityId" />
          <input type="hidden" name="athleteId" id="h-athleteId" />
          <input type="hidden" name="movingTimeSeconds" id="h-movingTimeSeconds" />
          <input type="hidden" name="startDateLocal" id="h-startDateLocal" />
          <input type="hidden" name="sectorEfforts" id="h-sectorEfforts" />
          <input type="hidden" name="komSegmentIds" id="h-komSegmentIds" />

          <div class="form-actions">
            <button type="submit" class="primary-button" id="confirm-btn">
              Confirm Submission
            </button>
            <a href="/submit" class="secondary-button">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    // Decode base64url-encoded payload from query string.
    // Encoding is the inverse of btoa() with +→- /→_ =→(removed) used in submit.astro.
    function fromBase64url(encoded: string): Record<string, unknown> {
      let b = encoded.replace(/-/g, "+").replace(/_/g, "/");
      while (b.length % 4) b += "=";
      return JSON.parse(atob(b));
    }

    // Format total seconds as HH:MM:SS — mirrors scoring.ts formatDuration.
    function formatTime(totalSeconds: number): string {
      const h = Math.floor(totalSeconds / 3600);
      const m = Math.floor((totalSeconds % 3600) / 60);
      const s = totalSeconds % 60;
      return [h, m, s].map((v) => String(v).padStart(2, "0")).join(":");
    }

    type Payload = {
      activityId?: string | number;
      athleteId?: string | number;
      movingTimeSeconds?: number;
      startDateLocal?: string;
      sectorEfforts?: Record<string, number>;
      komSegmentIds?: string[];
    };

    function renderPreview(payload: Payload): void {
      // Date display
      const dateEl = document.getElementById("activity-date");
      if (dateEl) {
        const date = payload.startDateLocal ?? "";
        if (date.startsWith("2026-06-06")) {
          dateEl.textContent = "Day 1 — Saturday, June 6";
        } else if (date.startsWith("2026-06-07")) {
          dateEl.textContent = "Day 2 — Sunday, June 7";
        } else {
          dateEl.textContent = date ? date.slice(0, 10) : "";
        }
      }

      // Day 1 preview — moving time (35% weight)
      const day1El = document.getElementById("day1-preview");
      if (day1El) {
        const movingTime = payload.movingTimeSeconds ?? 0;
        if (movingTime > 0) {
          day1El.innerHTML = `
            <p class="preview-label">Day 1 · Moving Time</p>
            <p class="preview-value">${formatTime(movingTime)}</p>
            <p class="preview-explain">Your moving time counts for <strong>35%</strong> of your overall score, benchmarked against the fastest rider in your category.</p>
          `;
        } else {
          day1El.innerHTML = `
            <p class="preview-label">Day 1 · Moving Time</p>
            <p class="preview-value">—</p>
            <p class="preview-explain">Not applicable for Day 2 activities.</p>
          `;
        }
      }

      // Day 2 Sectors preview — timed sectors (45% weight)
      const sectorsEl = document.getElementById("sectors-preview");
      if (sectorsEl) {
        const sectorEfforts = payload.sectorEfforts ?? {};
        const sectorCount = Object.keys(sectorEfforts).length;
        const sectorTotal = Object.values(sectorEfforts).reduce(
          (a: number, b: number) => a + b,
          0
        );
        if (sectorCount > 0) {
          sectorsEl.innerHTML = `
            <p class="preview-label">Day 2 · Timed Sectors</p>
            <p class="preview-value">${sectorCount} of 7 sectors · ${formatTime(sectorTotal)}</p>
            <p class="preview-explain">Your combined sector time counts for <strong>45%</strong> of your overall score, benchmarked against the fastest aggregate in your category.</p>
          `;
        } else {
          sectorsEl.innerHTML = `
            <p class="preview-label">Day 2 · Timed Sectors</p>
            <p class="preview-value">—</p>
            <p class="preview-explain">No timed sectors matched for this activity.</p>
          `;
        }
      }

      // Day 2 KOM preview — KOM segments (20% weight)
      const komEl = document.getElementById("kom-preview");
      if (komEl) {
        const komCount = (payload.komSegmentIds ?? []).length;
        if (komCount > 0) {
          komEl.innerHTML = `
            <p class="preview-label">Day 2 · KOM Points</p>
            <p class="preview-value">${komCount} of 3 KOM segments</p>
            <p class="preview-explain">KOM points count for <strong>20%</strong> of your overall score, based on how your climb times compare to other riders.</p>
          `;
        } else {
          komEl.innerHTML = `
            <p class="preview-label">Day 2 · KOM Points</p>
            <p class="preview-value">—</p>
            <p class="preview-explain">No KOM segments matched for this activity.</p>
          `;
        }
      }
    }

    function populateHiddenFields(payload: Payload): void {
      const set = (id: string, value: unknown) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) {
          el.value =
            typeof value === "object" ? JSON.stringify(value) : String(value ?? "");
        }
      };
      set("h-activityId", payload.activityId);
      set("h-athleteId", payload.athleteId);
      set("h-movingTimeSeconds", payload.movingTimeSeconds);
      set("h-startDateLocal", payload.startDateLocal);
      set("h-sectorEfforts", payload.sectorEfforts ?? {});
      set("h-komSegmentIds", payload.komSegmentIds ?? []);
    }

    function setupForm(): void {
      const form = document.getElementById("confirm-form") as HTMLFormElement;
      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const nameInput = document.getElementById("rider-name") as HTMLInputElement;
        const categorySelect = document.getElementById(
          "rider-category"
        ) as HTMLSelectElement;
        const name = nameInput.value.trim();
        const category = categorySelect.value;

        // Reset custom validity before re-checking
        nameInput.setCustomValidity("");
        categorySelect.setCustomValidity("");

        if (!name) {
          nameInput.setCustomValidity("Please enter your display name.");
          nameInput.reportValidity();
          return;
        }

        if (!category) {
          categorySelect.setCustomValidity("Please select your category.");
          categorySelect.reportValidity();
          return;
        }

        // Phase 7 will POST to /api/submit-result.
        // For now, show a placeholder confirmation while the payload is preserved
        // in the hidden fields.
        const btn = document.getElementById("confirm-btn") as HTMLButtonElement;
        btn.textContent = "Submission ready";
        btn.disabled = true;
      });

      // Clear custom validity on interaction to allow re-submission attempts
      (document.getElementById("rider-name") as HTMLInputElement).addEventListener(
        "input",
        function (this: HTMLInputElement) {
          this.setCustomValidity("");
        }
      );
      (
        document.getElementById("rider-category") as HTMLSelectElement
      ).addEventListener("change", function (this: HTMLSelectElement) {
        this.setCustomValidity("");
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      const params = new URLSearchParams(window.location.search);
      const encoded = params.get("payload");

      if (!encoded) {
        window.location.href = "/submit";
        return;
      }

      let payload: Payload;
      try {
        payload = fromBase64url(encoded) as Payload;
      } catch (_) {
        window.location.href = "/submit";
        return;
      }

      renderPreview(payload);
      populateHiddenFields(payload);
      setupForm();
    });
  </script>

  <style>
    .confirm-shell {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: var(--page-gutter, 1.5rem);
    }

    .confirm-card {
      position: relative;
      z-index: 1;
      max-width: 42rem;
      width: 100%;
      background: var(--color-fir-900, #17231f);
      border: 1px solid var(--color-fir-700, #2f463d);
      border-radius: 0.75rem;
      padding: clamp(2rem, 6vw, 3.5rem);
      box-shadow: var(--shadow-poster);
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .confirm-heading {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 4vw, 2.25rem);
      font-weight: 600;
      color: var(--color-mist-50);
      line-height: 1.1;
      letter-spacing: -0.04em;
    }

    .confirm-date {
      font-family: var(--font-sans);
      font-size: 1rem;
      color: var(--color-fern-500, #6d8977);
      font-weight: 600;
      margin: 0;
    }

    /* Score preview */
    .preview-heading {
      font-family: var(--font-display);
      font-size: 1.25rem;
      color: var(--color-mist-50);
      margin-bottom: 0.75rem;
    }

    .preview-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    @media (min-width: 640px) {
      .preview-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .preview-grid > div {
      background: var(--color-night-975, #060908);
      border: 1px solid var(--color-fir-700, #2f463d);
      border-radius: 0.5rem;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .preview-label {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-fern-500, #6d8977);
      margin: 0;
    }

    .preview-value {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--color-mist-50);
      line-height: 1.2;
      margin: 0;
    }

    .preview-explain {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      line-height: 1.5;
      color: var(--color-mist-200, #d1cabd);
      margin: 0;
    }

    .preview-explain strong {
      color: var(--color-ember-400, #dd8258);
    }

    .preview-note {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      color: var(--color-mist-200, #d1cabd);
      font-style: italic;
      margin-top: 0.5rem;
      margin-bottom: 0;
    }

    /* Identity form */
    #confirm-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .form-field label {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-mist-50);
    }

    .form-field input,
    .form-field select {
      width: 100%;
      box-sizing: border-box;
      padding: 0.75rem 1rem;
      background: var(--color-night-975, #060908);
      border: 1px solid var(--color-fir-700, #2f463d);
      border-radius: 0.375rem;
      color: var(--color-mist-50, #f2eee6);
      font-family: var(--font-sans);
      font-size: 1rem;
      outline: none;
      transition: border-color 0.15s ease;
    }

    .form-field input:focus,
    .form-field select:focus {
      border-color: var(--color-fern-500, #6d8977);
    }

    .form-field input::placeholder {
      color: var(--color-mist-400, #9f998d);
    }

    .form-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    /* Eyebrow — matches global and submit.astro pattern */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--color-gold-400, #c7a068);
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 3rem;
      height: 1px;
      background: currentColor;
      opacity: 0.55;
    }

    /* Primary button — scoped, matches submit.astro */
    .primary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.5rem;
      background: var(--color-mist-50, #f2eee6);
      color: var(--color-night-950, #0a1110);
      font-family: var(--font-sans);
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 999px;
      cursor: pointer;
      text-decoration: none;
      transition: box-shadow 0.15s ease, transform 0.15s ease;
      box-shadow: var(--shadow-button);
    }

    .primary-button:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.36);
    }

    .primary-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Secondary button — scoped, matches error.astro */
    .secondary-button {
      display: inline-flex;
      align-items: center;
      padding: 0.65rem 1.4rem;
      background: transparent;
      color: var(--color-mist-50);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 500;
      border: 1px solid var(--color-fern-500, #6d8977);
      border-radius: 0.375rem;
      text-decoration: none;
      transition: border-color 0.15s ease, color 0.15s ease;
    }

    .secondary-button:hover {
      border-color: var(--color-mist-200, #d1cabd);
      color: var(--color-mist-200, #d1cabd);
    }
  </style>
</BaseLayout>
